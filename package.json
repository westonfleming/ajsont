{
  "name": "@westonfleming/ajsont",
  "version": "0.1.0",
  "description": "Declarative JSON-to-JSON transformation using JSONPath",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check:publint": "publint",
    "check:attw": "npm pack && attw *.tgz && rm *.tgz",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "prepublishOnly": "npm run build && npm run check:publint && npm run check:attw"
  },
  "keywords": [
    "json",
    "transform",
    "jsonpath",
    "mapping",
    "event-normalization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/westonfleming/ajsont.git"
  },
  "dependencies": {
    "jsonpath-plus": "^10.4.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@types/node": "^26.0.0",
    "publint": "^0.3.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
